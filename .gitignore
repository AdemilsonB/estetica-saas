# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Worktrees ────────────────────────────────────────────────────────────────
.worktrees/

# ─── Dependências ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Build / Output ──────────────────────────────────────────────────────────
/.next/
/out/
/build
/.swc/
/.turbo/
/storybook-static/

# ─── Testes ──────────────────────────────────────────────────────────────────
/coverage
/cypress/videos/
/cypress/screenshots/
/playwright-report/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Variáveis de ambiente — NUNCA commitar arquivos com credenciais reais ───
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
# .env.example DEVE ser commitado — contém apenas valores dummy de referência

# ─── Banco de dados local ────────────────────────────────────────────────────
*.db
*.db-journal
*.sqlite
*.sqlite3

# ─── IDEs e editores ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.orig

# ─── Deploy ──────────────────────────────────────────────────────────────────
.vercel

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Prisma ──────────────────────────────────────────────────────────────────
/src/generated/prisma
/prisma/generated/

# ─── Certificados e chaves ───────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
.superpowers/
