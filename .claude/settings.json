{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git worktree list:*)",
      "Bash(npm run *)",
      "Bash(npx tsc:*)",
      "Bash(npx prisma generate:*)",
      "Bash(npx prisma validate:*)",
      "Bash(npx prisma format:*)",
      "Bash(npx prisma studio:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(npx prisma migrate reset:*)",
      "Bash(npx prisma db push:*)"
    ]
  }
}
