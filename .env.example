# =============================================================================
# ESTE ARQUIVO É UM TEMPLATE — COPIE PARA .env.local E PREENCHA OS VALORES
# NUNCA commite .env, .env.local ou qualquer arquivo com credenciais reais
# =============================================================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Database (Supabase / PostgreSQL)
# =============================================================================
# Conexão pooled — usada pela aplicação em runtime (via Prisma)
# No Supabase: Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.abcdefghijklmnopqrst:MinhaS3nhaF0rte@aws-eu-east-1.pooler.supabase.com:6543/postgres

# Conexão direta — usada pelo Prisma CLI para migrations e seed
# No Supabase: Settings → Database → Connection string → Direct connection
DIRECT_URL=postgresql://postgres:MinhaS3nhaF0rte@db.abcdefghijklmnopqrst.supabase.co:5432/postgres

# =============================================================================
# Supabase
# =============================================================================
# Painel Supabase → Settings → API

# URL do projeto
SUPABASE_URL=https://abcdefghijklmnopqrst.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://abcdefghijklmnopqrst.supabase.co

# Chave anônima pública — pode ser exposta no frontend
SUPABASE_ANON_KEY=sb_publishable_AbCdEfGhIjKlMnOpQrStUvWxYz0123456789ABCD
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_AbCdEfGhIjKlMnOpQrStUvWxYz0123456789ABCD

# Chave de service role — NUNCA expor no frontend, apenas no servidor
SUPABASE_SERVICE_ROLE_KEY=sb_secret_AbCdEfGhIjKlMnOpQrStUvWxYz0123456789ABCDsecret

# =============================================================================
# Auth
# =============================================================================
# Segredo para validação de JWT — gere um valor aleatório forte em produção
# Exemplo: openssl rand -base64 32
AUTH_JWT_SECRET=sb_secret_AbCdEfGhIjKlMnOpQrStUvWxYz0123456789ABCDsecret

# =============================================================================
# Queue / Jobs assíncronos (pg-boss)
# =============================================================================
PG_BOSS_SCHEMA=pgboss

# =============================================================================
# Integrações externas
# =============================================================================

# WhatsApp — Twilio
# Painel Twilio → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Número de envio (sandbox Twilio: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# URL base da aplicação (usada em webhooks e deep-links)
APP_URL=http://localhost:3000

# Template SIDs — usar SIDs reais após aprovação Meta; sandbox não exige SIDs
TWILIO_TPL_CONFIRMATION=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TPL_CONFIRMED=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TPL_REMINDER=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TPL_CANCELLATION=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TPL_NO_SHOW=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email transacional — Resend
# Painel Resend → API Keys → Create API Key
# Em dev: confirmação de email é bypassada via /api/dev/confirm-email
# Em produção: configurar SMTP no Supabase Dashboard
#   → Project Settings → Auth → SMTP Settings
#   Host: smtp.resend.com | Port: 465 | User: resend | Senha: API Key abaixo
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Admin API (backoffice interno)
ADMIN_API_SECRET=dev-admin-secret-alterar-em-producao

# Admin — chave secreta para tokens de impersonação (mín. 32 chars)
# Gere um valor forte: openssl rand -base64 32
ADMIN_IMPERSONATE_SECRET=sua-chave-secreta-aqui-minimo-32-caracteres

# =============================================================================
# NOTAS DE SEGURANÇA
# =============================================================================
# 1. Copie este arquivo: cp .env.example .env.local
# 2. Preencha os valores reais no .env.local
# 3. NUNCA commite .env.local ou qualquer arquivo com valores reais
# 4. Em produção, configure as variáveis no painel da Vercel:
#    Vercel → Project → Settings → Environment Variables
# 5. Variáveis NEXT_PUBLIC_* são expostas ao browser — apenas valores públicos
# 6. SUPABASE_SERVICE_ROLE_KEY nunca deve ter prefixo NEXT_PUBLIC_
