# =============================================================================
# ESTE ARQUIVO É UM TEMPLATE — COPIE PARA .env.local E PREENCHA OS VALORES
# NUNCA commite .env, .env.local ou qualquer arquivo com credenciais reais
# =============================================================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Database (Supabase / PostgreSQL)
# =============================================================================
# Conexão pooled — usada pela aplicação em runtime (via Prisma adapter-pg)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/estetica_saas
DATABASE_URL_PRODUCAO=postgresql://postgres.vcbkcwcgejukjjagcleh:SaaSEstetica@aws-1-us-east-2.pooler.supabase.com:6543/postgres

# Conexão direta — usada pelo Prisma CLI para migrations e seed
# No Supabase: Settings → Database → Connection string → Direct connection
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/estetica_saas
DIRECT_URL_PRODUCAO=postgresql://postgres:SaaSEstetica@db.vcbkcwcgejukjjagcleh.supabase.co:5432/postgres
# =============================================================================
# Supabase
# =============================================================================
# Painel Supabase → Settings → API

# URL do projeto (usada no servidor)
SUPABASE_URL=https://your-project-ref.supabase.co

# Chave anônima pública — pode ser exposta no frontend
SUPABASE_ANON_KEY=your-public-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Chave de service role — NUNCA expor no frontend, apenas no servidor
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Auth
# =============================================================================
# Segredo para validação de JWT — gere um valor aleatório forte em produção
# Exemplo: openssl rand -base64 32
AUTH_JWT_SECRET=change-me-to-a-random-secret

# =============================================================================
# Queue / Jobs assíncronos (pg-boss)
# =============================================================================
# Schema no PostgreSQL onde o pg-boss cria suas tabelas de controle
PG_BOSS_SCHEMA=pgboss

# =============================================================================
# Integrações externas
# =============================================================================

# WhatsApp — Z-API
# Credencial global do client Z-API (painel Z-API → Client Token)
ZAPI_CLIENT_TOKEN=your-z-api-client-token
# Credenciais por tenant ficam no banco: Tenant.zApiInstanceId / Tenant.zApiToken

# =============================================================================
# NOTAS DE SEGURANÇA
# =============================================================================
# 1. Copie este arquivo para .env.local: cp .env.example .env.local
# 2. Preencha os valores reais no .env.local
# 3. NUNCA commite .env.local ou qualquer arquivo com valores reais
# 4. Em produção, configure as variáveis diretamente no painel da Vercel
#    (Vercel → Project → Settings → Environment Variables)
# 5. Variáveis NEXT_PUBLIC_* são expostas ao browser — use apenas para
#    valores que podem ser públicos (URL do Supabase, chave anon)
# 6. SUPABASE_SERVICE_ROLE_KEY nunca deve ter prefixo NEXT_PUBLIC_

NEXT_PUBLIC_SUPABASE_URL=https://vcbkcwcgejukjjagcleh.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_aQQhARZuZ5mm9akW0H42Rw_SL28qYQ0
